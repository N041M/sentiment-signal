DATABASE_URL=postgresql://sentiment:sentiment@localhost:5432/sentiment_signal

# NewsAPI — https://newsapi.org/
NEWSAPI_KEY=

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Reddit PRAW — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SentimentSignal/0.1 by your_username

# YouTube Data API v3 — https://console.cloud.google.com/
YOUTUBE_API_KEY=

# Bluesky (AT Protocol) — create an app password: Settings -> App Passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Weights & Biases — https://wandb.ai/
WANDB_PROJECT=sentiment-signal
WANDB_API_KEY=

# HuggingFace — https://huggingface.co/settings/tokens (free read token)
# Required for downloading FinBERT and other models without rate-limiting
HF_TOKEN=

# NLP inference settings
NLP_BATCH_SIZE=32
EMBEDDING_DIM=768
REACTION_WINDOW_HOURS=48
